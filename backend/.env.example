# ─────────────────────────────────────────────────────────────────
#  SGOS Reportes – Plantilla de variables de entorno
#  Copia este archivo como .env y rellena los valores reales.
#  NO pongas credenciales reales en este archivo.
# ─────────────────────────────────────────────────────────────────

# Cadena de conexión a Neon.tech (PostgreSQL)
DATABASE_URL=postgresql://USUARIO:CONTRASEÑA@HOST/neondb?sslmode=require&channel_binding=require

# Secreto para firmar los JWT
# Genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TU_SECRETO_JWT_ALEATORIO_AQUI

# Tiempo de expiración del token
JWT_EXPIRY=8h

# Puerto del servidor backend
PORT=3001

# Orígenes permitidos para CORS
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
